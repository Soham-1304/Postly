{
  "info": {
    "_postman_id": "postly-api-collection",
    "name": "Postly API",
    "description": "Complete API collection for Postly — Multi-Platform AI Content Publishing Engine.\n\nSet the `baseUrl` variable to your live Render URL before using.\n\nWorkflow:\n1. Register → Login → copy accessToken into the `token` variable\n2. All protected routes use Bearer auth automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://postly-api.onrender.com",
      "type": "string",
      "description": "Live Render deployment URL"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT access token — fill after login"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string",
      "description": "JWT refresh token — fill after login"
    },
    {
      "key": "postId",
      "value": "",
      "type": "string",
      "description": "Post ID — fill after publishing"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Soham Karandikar\",\n  \"email\": \"soham@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"soham@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "profile"]
            }
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Soham Karandikar\",\n  \"bio\": \"Building cool stuff\",\n  \"defaultTone\": \"professional\",\n  \"defaultLanguage\": \"en\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "profile"]
            }
          },
          "response": []
        },
        {
          "name": "Add Social Account",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"twitter\",\n  \"accessToken\": \"your_twitter_access_token\",\n  \"refreshToken\": null,\n  \"handle\": \"@yourhandle\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/social-accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "social-accounts"]
            }
          },
          "response": []
        },
        {
          "name": "List Social Accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/social-accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "social-accounts"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Social Account",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/social-accounts/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "social-accounts", ":id"],
              "variable": [{"key": "id", "value": "replace-with-account-id"}]
            }
          },
          "response": []
        },
        {
          "name": "Update AI Keys",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"openaiKey\": \"sk-your-openai-key\",\n  \"anthropicKey\": \"sk-ant-your-anthropic-key\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/ai-keys",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "ai-keys"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "Generate Content (Gemini)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"AI is transforming how developers write code — tools like GitHub Copilot and Cursor are making 10x engineers a reality\",\n  \"post_type\": \"announcement\",\n  \"platforms\": [\"twitter\", \"linkedin\"],\n  \"tone\": \"professional\",\n  \"language\": \"en\",\n  \"model\": \"gemini\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/generate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "generate"]
            }
          },
          "response": []
        },
        {
          "name": "Generate Content (All Platforms)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"We just launched Postly — a Telegram bot that auto-generates and posts content to all your social platforms using AI\",\n  \"post_type\": \"announcement\",\n  \"platforms\": [\"twitter\", \"linkedin\", \"instagram\", \"threads\"],\n  \"tone\": \"witty\",\n  \"language\": \"en\",\n  \"model\": \"gemini\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/generate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "generate"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Publish Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.post?.id) {",
                  "  pm.collectionVariables.set('postId', res.data.post.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"AI is rapidly changing software development workflows\",\n  \"postType\": \"announcement\",\n  \"tone\": \"professional\",\n  \"language\": \"en\",\n  \"model\": \"gemini\",\n  \"platforms\": [\"twitter\"],\n  \"content\": {\n    \"twitter\": {\n      \"content\": \"AI is transforming how developers work. Tools like Copilot are making every developer 10x more effective. The future is here. #AI #DevTools #Productivity\",\n      \"char_count\": 158,\n      \"hashtags\": [\"#AI\", \"#DevTools\", \"#Productivity\"]\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts/publish",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "publish"]
            }
          },
          "response": []
        },
        {
          "name": "Schedule Post",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Scheduled post about AI and automation\",\n  \"postType\": \"announcement\",\n  \"tone\": \"professional\",\n  \"language\": \"en\",\n  \"model\": \"gemini\",\n  \"platforms\": [\"twitter\", \"linkedin\"],\n  \"publishAt\": \"2026-05-01T10:00:00.000Z\",\n  \"content\": {\n    \"twitter\": {\n      \"content\": \"The AI revolution in software is just getting started. #AI #Future\",\n      \"char_count\": 63,\n      \"hashtags\": [\"#AI\", \"#Future\"]\n    },\n    \"linkedin\": {\n      \"content\": \"We are witnessing a fundamental shift in how software is built. AI-powered tools are not replacing developers — they are making each developer significantly more capable.\",\n      \"char_count\": 168,\n      \"hashtags\": [\"#AI\", \"#SoftwareDevelopment\", \"#Innovation\"]\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts/schedule",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "schedule"]
            }
          },
          "response": []
        },
        {
          "name": "List Posts (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"},
                {"key": "status", "value": "published", "disabled": true},
                {"key": "platform", "value": "twitter", "disabled": true}
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Retry Failed Post",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/retry",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}", "retry"]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Scheduled Post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "stats"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
